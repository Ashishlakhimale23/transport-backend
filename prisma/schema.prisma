// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generate/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Enums (mapped to readable identifiers)
enum UserRole {
  admin
  contractor
  driver
}

enum VehicleWheel {
  V4   @map("4")
  V6   @map("6")
  V10  @map("10")
  V12  @map("12")
}

enum GoodsType {
  HANDLE_WITH_CARE @map("handlewithcare")
  AUTOMOBILE       @map("automobile")
}

enum VehicleCategory {
  OPEN     @map("open")
  SEMIOPEN @map("semiopen")
  CONTAINER @map("container")
}

enum Status_Mode {
  PENDING @map("pending")
  ADMIN_APPROVAL @map("admin_approval")
  APPROVED @map("approved")
  DECLINED @map("declined")
}

enum DeliveryStatus {
  IN_TRANSIT @map("in_transit")
  DELIVERED @map("delivered")
  COMPLETED @map("completed")
}

// Models
model User {
  id                        Int       @id @default(autoincrement())
  email                     String    @db.VarChar(100)
  username                  String    @db.VarChar(25)
  role                      UserRole
  password                  String    @db.VarChar(100)
  upiID                     String    @default("hellohello")
  contact                   String
  regularPracticeLocation   String
  vechileType               VehicleType[] @relation("UserVehicles")
  contractsCreated          Contract[] @relation("ContractorContracts")
  contractsCarried          Contract[] @relation("GoodsCarrierContracts")
  bids                      Bid[]
  givenRatings     Rating[] @relation("GivenRatings")
  receivedRatings  Rating[] @relation("ReceivedRatings")

  @@map("user")
}

model Contract {
  id                      Int               @id @default(autoincrement())
  weight                  Float
  pickupDate              DateTime
  dropDate                DateTime
  startLocation           String            @db.VarChar(100)
  endLocation             String            @db.VarChar(100)
  approxKms               Int
  contractorId            Int
  goodsCarrierId          Int?
  typeOfVehicle           VehicleWheel
  insured                 Boolean
  winningPrice            Int?
  type                    String 
  createdAt               DateTime          @default(now())
  description             String            @default("")
  requirements            String[]          @default([])
  deliveryStatus          DeliveryStatus?
  deliveryConfirmedAt     DateTime?
  deliverableNotes        String?           @default("")
  contractor              User              @relation("ContractorContracts", fields: [contractorId], references: [id], onDelete: Cascade)
  goodsCarrier            User?             @relation("GoodsCarrierContracts", fields: [goodsCarrierId], references: [id], onDelete: Cascade)
  bids                    Bid[]
  ratings                 Rating[]

  @@map("contract")
}

model Bid {
  id         Int      @id @default(autoincrement())
  userId     Int
  contractId Int
  amount     Int
  status     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())


  @@map("bids")
}

model VehicleType {
  id                Int             @id @default(autoincrement())
  wheelers          VehicleWheel
  category          VehicleCategory
  brand             String          @db.VarChar(50)
  driverId Int
  driver     User         @relation("UserVehicles", fields: [driverId], references: [id], onDelete: Cascade)

  @@map("vechiletype")
}


model Rating {
  id           Int      @id @default(autoincrement())
  value        Int      
  comment      String?
  raterId      Int
  ratedUserId  Int
  contractId   Int
  createdAt    DateTime @default(now())
  rater        User     @relation("GivenRatings", fields: [raterId], references: [id], onDelete: Cascade)
  ratedUser    User     @relation("ReceivedRatings", fields: [ratedUserId], references: [id], onDelete: Cascade)
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([raterId, contractId]) 
  @@map("ratings")
}